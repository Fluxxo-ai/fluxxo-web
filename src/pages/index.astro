---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout
  title="Agencia de Marketing Automatizado e Inteligencia Artificial para Empresas | Fluxxo"
  description="Captamos clientes, automatizamos procesos y optimizamos resultados mediante publicidad digital, automatización e IA. Desde 447€/mes. Sin permanencias."
>
  <Nav />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-grid"></div>
      <div class="hero-glow-1"></div>
      <div class="hero-glow-2"></div>
      <div class="hero-line hero-line-1"></div>
      <div class="hero-line hero-line-2"></div>
    </div>
    <div class="hero-inner">
      <div class="hero-left">
        <h1 class="hero-h1">
          Agencia de marketing<br />
          automatizado e <span class="accent">inteligencia<br />artificial</span> para empresas<br />
          que quieren conseguir<br />más clientes
        </h1>
        <p class="hero-sub">
          Captamos clientes, automatizamos procesos y optimizamos resultados mediante <strong>publicidad digital, automatización e IA.</strong>
        </p>
        <div class="hero-btns">
          <a href="#contacto" class="btn-primary">Solicitar auditoría gratuita →</a>
          <a href="#servicios" class="btn-secondary">Ver servicios</a>
        </div>
      </div>
      <div class="hero-metrics">
        <div class="metric-card featured">
          <div class="metric-value"><em>3</em>× más leads</div>
          <div class="metric-label">Media en primeros 90 días</div>
          <div class="metric-bar"><div class="metric-fill" style="width:75%"></div></div>
        </div>
        <div class="metric-card">
          <div class="metric-value">−<em>70</em>%</div>
          <div class="metric-label">Coste vs agencia tradicional</div>
          <div class="metric-bar"><div class="metric-fill" style="width:70%"></div></div>
        </div>
        <div class="metrics-small">
          <div class="metric-small">
            <div class="metric-small-value"><em>24</em>/7</div>
            <div class="metric-small-label">Sistema activo</div>
          </div>
          <div class="metric-small">
            <div class="metric-small-value"><em>48</em>h</div>
            <div class="metric-small-label">Para empezar</div>
          </div>
        </div>
      </div>
    </div>
    <div class="scroll-hint">
      <span class="scroll-hint-text">scroll</span>
      <div class="scroll-hint-arrow">↓</div>
    </div>
  </section>

  <!-- TICKER -->
  <div class="ticker">
    <div class="ticker-track">
      <div class="ticker-item">
        <em>Gestión de redes sociales</em><span class="ticker-sep">·</span>
        Reputación online<span class="ticker-sep">·</span>
        <em>Captación de leads</em><span class="ticker-sep">·</span>
        Email marketing<span class="ticker-sep">·</span>
        <em>Publicidad digital</em><span class="ticker-sep">·</span>
        Análisis de competencia<span class="ticker-sep">·</span>
        <em>WhatsApp IA</em><span class="ticker-sep">·</span>
        SEO estratégico<span class="ticker-sep">·</span>
        <em>Automatizaciones avanzadas</em><span class="ticker-sep">·</span>
        Reporting mensual<span class="ticker-sep">·</span>
      </div>
      <div class="ticker-item">
        <em>Gestión de redes sociales</em><span class="ticker-sep">·</span>
        Reputación online<span class="ticker-sep">·</span>
        <em>Captación de leads</em><span class="ticker-sep">·</span>
        Email marketing<span class="ticker-sep">·</span>
        <em>Publicidad digital</em><span class="ticker-sep">·</span>
        Análisis de competencia<span class="ticker-sep">·</span>
        <em>WhatsApp IA</em><span class="ticker-sep">·</span>
        SEO estratégico<span class="ticker-sep">·</span>
        <em>Automatizaciones avanzadas</em><span class="ticker-sep">·</span>
        Reporting mensual<span class="ticker-sep">·</span>
      </div>
    </div>
  </div>

  <!-- SERVICIOS -->
  <section id="servicios" class="section">
    <div class="section-inner">
      <div class="section-tag reveal">Lo que hacemos</div>
      <h2 class="section-title reveal">Todo el marketing de tu negocio,<br /><span class="dim">gestionado para ti.</span></h2>
      <p class="section-sub reveal">Un sistema completo que capta clientes, cuida tu imagen online y mantiene activas tus redes sociales. Sin que tengas que dedicarle tiempo.</p>
      <div class="services-grid reveal">
        <div class="service-cell">
          <div class="service-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4D9EFF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <div class="service-name">Contenido para redes sociales</div>
          <div class="service-desc">Publicaciones semanales para Instagram, LinkedIn, Facebook, TikTok y Google Business. Con textos, imágenes y vídeos incluidos</div>
        </div>
        <div class="service-cell">
          <div class="service-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4D9EFF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <div class="service-name">Gestión de reseñas y reputación</div>
          <div class="service-desc">Monitorizamos y respondemos tus reseñas de Google en minutos. Detectamos valoraciones negativas al instante para actuar rápido</div>
        </div>
        <div class="service-cell">
          <div class="service-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4D9EFF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div class="service-name">Captación y seguimiento de leads</div>
          <div class="service-desc">Respondemos a tus contactos en segundos, los cualificamos y agendamos llamadas automáticamente. Nunca pierdas una oportunidad</div>
        </div>
        <div class="service-cell">
          <div class="service-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4D9EFF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <div class="service-name">WhatsApp IA</div>
          <div class="service-desc">Un asistente de IA disponible 24/7 en WhatsApp Business que responde dudas, envía información y agenda citas por ti</div>
        </div>
        <div class="service-cell">
          <div class="service-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4D9EFF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <div class="service-name">Creatividades para anuncios</div>
          <div class="service-desc">Generamos textos, imágenes y vídeos para tus campañas en Meta, Google y TikTok Ads. Listos para publicar cada semana</div>
        </div>
        <div class="service-cell">
          <div class="service-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4D9EFF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <div class="service-name">Análisis de competencia</div>
          <div class="service-desc">Cada semana recibes un informe con lo que están haciendo tus competidores: sus anuncios, cambios en SEO y nuevas ofertas</div>
        </div>
        <div class="service-cell">
          <div class="service-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4D9EFF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          </div>
          <div class="service-name">Informe mensual de resultados</div>
          <div class="service-desc">Cada mes recibes un resumen claro de todo lo conseguido: leads, publicaciones, reseñas y recomendaciones para el siguiente mes</div>
        </div>
        <div class="service-cell">
          <div class="service-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4D9EFF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div class="service-name">Email marketing</div>
          <div class="service-desc">Newsletters, secuencias de bienvenida y campañas de email personalizadas para mantener el contacto con tus clientes</div>
        </div>
        <div class="service-cell">
          <div class="service-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4D9EFF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div class="service-name">SEO estratégico</div>
          <div class="service-desc">Artículos optimizados para que Google te encuentre, análisis de palabras clave y mejoras técnicas en tu web</div>
        </div>
        <div class="service-cell">
          <div class="service-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4D9EFF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <div class="service-name">Gestión de publicidad digital</div>
          <div class="service-desc">Gestionamos tus campañas de pago en Meta, Google y TikTok para conseguir el máximo retorno de tu inversión publicitaria</div>
        </div>
      </div>
    </div>
  </section>

  <!-- RESULTADOS -->
  <section id="resultados" class="section">
    <div class="section-inner">
      <div class="section-tag reveal">Resultados</div>
      <h2 class="section-title reveal">Números que<br /><span class="dim">hablan por nosotros.</span></h2>
      <p class="section-sub reveal">Resultados conseguidos con nuestros clientes en los primeros 90 días de activación del sistema.</p>
      <div class="results-grid">
        <div class="result-card reveal reveal-delay-1">
          <div class="result-sector">Deporte y entretenimiento · Prisma Padel</div>
          <div class="result-number">+<em>312</em>%</div>
          <div class="result-desc">Incremento de inscripciones al evento en 45 días</div>
          <div class="result-stats">
            <div class="result-stat">Alcance orgánico antes <span>bajo</span></div>
            <div class="result-stat">Alcance tras campaña <span class="accent">+18.000</span></div>
            <div class="result-stat">Coste por inscripción <span class="positive">−54%</span></div>
          </div>
        </div>
        <div class="result-card reveal reveal-delay-2">
          <div class="result-sector">Sector salud · Clínica Dental</div>
          <div class="result-number"><em>5</em>★</div>
          <div class="result-desc">Valoración perfecta en Google mantenida con gestión activa de reseñas</div>
          <div class="result-stats">
            <div class="result-stat">Reseñas antes <span>23</span></div>
            <div class="result-stat">Reseñas después <span class="accent">81</span></div>
            <div class="result-stat">Tiempo de respuesta <span class="positive">2 min</span></div>
          </div>
        </div>
        <div class="result-card reveal reveal-delay-3">
          <div class="result-sector">Reformas del hogar · Gen Builders</div>
          <div class="result-number">−<em>62</em>%</div>
          <div class="result-desc">Reducción del coste de adquisición de cada nuevo cliente</div>
          <div class="result-stats">
            <div class="result-stat">Coste por cliente antes <span>340€</span></div>
            <div class="result-stat">Coste por cliente después <span class="accent">129€</span></div>
            <div class="result-stat">Retorno de la inversión <span class="positive">5.4×</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESO -->
  <section class="section">
    <div class="section-inner">
      <div class="section-tag reveal">El proceso</div>
      <h2 class="section-title reveal">Empiezas a ver resultados<br /><span class="dim">en menos de 48 horas.</span></h2>
      <div class="process-grid">
        <div class="process-step reveal reveal-delay-1">
          <div class="step-circle">01</div>
          <div class="step-title">Auditoría de tu negocio</div>
          <div class="step-desc">Analizamos tu situación actual, tu competencia y las oportunidades de crecimiento específicas para tu sector.</div>
        </div>
        <div class="process-step reveal reveal-delay-2">
          <div class="step-circle">02</div>
          <div class="step-title">Configuramos tu sistema</div>
          <div class="step-desc">Adaptamos todo al lenguaje de tu sector, tus competidores y tus objetivos específicos de captación y automatización.</div>
        </div>
        <div class="process-step reveal reveal-delay-3">
          <div class="step-circle">03</div>
          <div class="step-title">Tú apruebas todo</div>
          <div class="step-desc">Revisas el primer ciclo antes de publicar nada. Nada sale sin tu visto bueno, siempre.</div>
        </div>
        <div class="process-step reveal reveal-delay-4">
          <div class="step-circle">04</div>
          <div class="step-title">El sistema trabaja solo</div>
          <div class="step-desc">A partir de aquí, el sistema gestiona tu marketing 24/7. Tú recibes un informe mensual y te centras en tu negocio.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PLANES -->
  <section id="planes" class="section">
    <div class="section-inner">
      <div class="section-tag reveal">Planes y precios</div>
      <h2 class="section-title reveal">Una inversión que<br /><span class="dim">se paga sola.</span></h2>
      <p class="section-sub reveal">Una agencia tradicional cobra entre 1.500€ y 4.000€/mes por servicios equivalentes. Nosotros lo hacemos mejor, más rápido y desde 447€/mes.</p>
      <div class="plans-grid reveal">

        <!-- LAUNCH -->
        <div class="plan-card">
          <div class="plan-head">
            <div class="plan-name-label">Fluxxo Launch</div>
            <div class="plan-tagline">Construye una presencia digital sólida y automatiza las tareas básicas de marketing.</div>
            <div class="plan-price"><sup>€</sup>447<sub>/mes</sub></div>
            <div class="plan-annual">→ 397€/mes pagando anualmente</div>
            <div class="plan-save">Ahorra 600€/año</div>
          </div>
          <div class="plan-body">
            <div class="plan-feat">Sesión estratégica inicial</div>
            <div class="plan-feat">Redes sociales (Instagram, LinkedIn, Facebook)</div>
            <div class="plan-feat">Gestión de reseñas y reputación</div>
            <div class="plan-feat">Email marketing básico</div>
            <div class="plan-feat">Informes mensuales de resultados</div>
            <div class="plan-feat">Portal del cliente</div>
            <div class="plan-feat">Soporte por email</div>
          </div>
          <p class="plan-cta-text">Ahorra tiempo y profesionaliza tu presencia digital.</p>
          <a href="#contacto" class="plan-btn btn-plan-secondary">Empezar con Launch</a>
        </div>

        <!-- SCALE -->
        <div class="plan-card featured">
          <span class="popular-badge">El más elegido</span>
          <div class="plan-head featured-head">
            <div class="plan-name-label">Fluxxo Scale</div>
            <div class="plan-tagline">Sistema de captación automatizada para empresas que quieren crecer de forma predecible.</div>
            <div class="plan-price"><sup>€</sup>797<sub>/mes</sub></div>
            <div class="plan-annual">→ 697€/mes pagando anualmente</div>
            <div class="plan-save">Ahorra 1.200€/año</div>
          </div>
          <div class="plan-body">
            <div class="plan-feat">Todo lo de Launch</div>
            <div class="plan-feat">Captación de leads automatizada</div>
            <div class="plan-feat">Creatividades para anuncios</div>
            <div class="plan-feat">TikTok marketing</div>
            <div class="plan-feat">Análisis de competencia semanal</div>
            <div class="plan-feat">Email marketing avanzado con secuencias</div>
            <div class="plan-feat">Seguimiento automatizado de leads</div>
            <div class="plan-feat">Optimización continua de campañas</div>
            <div class="plan-feat">Reunión estratégica mensual</div>
          </div>
          <p class="plan-cta-text">Genera oportunidades de negocio de forma constante.</p>
          <a href="#contacto" class="plan-btn btn-plan-primary">Empezar con Scale</a>
        </div>

        <!-- DOMINATE -->
        <div class="plan-card">
          <div class="plan-head">
            <div class="plan-name-label">Fluxxo Dominate</div>
            <div class="plan-tagline">Sistema completo de crecimiento con captación, conversión y optimización avanzada.</div>
            <div class="plan-price"><sup>€</sup>1.397<sub>/mes</sub></div>
            <div class="plan-annual">→ 1.247€/mes pagando anualmente</div>
            <div class="plan-save">Ahorra 1.800€/año</div>
          </div>
          <div class="plan-body">
            <div class="plan-feat">Todo lo de Scale</div>
            <div class="plan-feat">Gestión de Paid Ads (Meta + Google)</div>
            <div class="plan-feat">WhatsApp IA 24/7</div>
            <div class="plan-feat">SEO estratégico</div>
            <div class="plan-feat">Dashboard de resultados en tiempo real</div>
            <div class="plan-feat">Optimización continua de conversiones</div>
            <div class="plan-feat">Reuniones estratégicas quincenales</div>
            <div class="plan-feat">Auditoría trimestral de crecimiento</div>
            <div class="plan-feat">Soporte prioritario</div>
            <div class="plan-feat">Automatizaciones avanzadas</div>
          </div>
          <p class="plan-cta-text">Escala tu marketing con un sistema completo de captación y automatización.</p>
          <a href="#contacto" class="plan-btn btn-plan-secondary">Empezar con Dominate</a>
        </div>

      </div>

      <div class="addons-label">Servicios adicionales disponibles en cualquier plan</div>
      <div class="addons-grid reveal">
        <div class="addon"><div class="addon-icon">⚡</div><div><div class="addon-name">Captación de leads</div><div class="addon-price">+199€/mes</div></div></div>
        <div class="addon"><div class="addon-icon">💬</div><div><div class="addon-name">WhatsApp IA</div><div class="addon-price">+249€/mes</div></div></div>
        <div class="addon"><div class="addon-icon">📣</div><div><div class="addon-name">Creatividades para anuncios</div><div class="addon-price">+149€/mes</div></div></div>
        <div class="addon"><div class="addon-icon">🤖</div><div><div class="addon-name">Chatbot para tu web</div><div class="addon-price">+199€/mes</div></div></div>
        <div class="addon"><div class="addon-icon">🔎</div><div><div class="addon-name">SEO estratégico</div><div class="addon-price">+199€/mes</div></div></div>
        <div class="addon"><div class="addon-icon">📱</div><div><div class="addon-name">Gestión publicidad digital</div><div class="addon-price">+299€/mes</div></div></div>
      </div>
    </div>
  </section>

  <FAQ />

  <!-- CLIENTES -->
  <section class="section clients-section">
    <div class="section-inner">
      <div class="section-tag reveal">Marcas que han confiado en nuestro equipo</div>
      <div class="clients-grid reveal">
        <div class="client-logo-item">
          <img src="/logos/floridablanca.png" alt="Clínica Dental Floridablanca" class="client-logo-img" />
        </div>
        <div class="client-logo-item">
          <img src="/logos/dr_rivera.png" alt="Dr. Pedro Rivera Clínica Dental" class="client-logo-img" />
        </div>
        <div class="client-logo-item">
          <img src="/logos/gen_builders.png" alt="Gen Builders" class="client-logo-img" />
        </div>
        <div class="client-logo-item">
          <img src="/logos/prisma.png" alt="Prisma Padel" class="client-logo-img" />
        </div>
        <div class="client-logo-item">
          <img src="/logos/swisscolors.png" alt="Swisscolors" class="client-logo-img" />
        </div>
      </div>
    </div>
  </section>

  <ContactForm />
  <Footer />
</Layout>
